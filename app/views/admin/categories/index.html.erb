<% if notice %><p class="flash-notice"><%= notice %></p><% end %>
<% if alert %><p class="flash-alert"><%= alert %></p><% end %>

<p class="breadcrumbs"><%= link_to "Admin", admin_path %> » Categories</p>

<h1>Categories</h1>

<table class="admin-table">
  <thead>
    <tr>
      <th>Name</th>
      <th>Slug</th>
      <th>In use</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @categories.each do |category| %>
      <tr>
        <td><%= category.name %></td>
        <td><code><%= category.slug %></code></td>
        <td><%= pluralize category.articles.size, "article" %></td>
        <td>
          <%= link_to "Edit", edit_admin_category_path(category) %>
          <% if category.articles.empty? %>
            &middot;
            <%= button_to "Delete", admin_category_path(category), method: :delete,
                          data: { turbo_confirm: "Delete #{category.name}?" },
                          class: "linklike" %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<p class="admin-actions">
  <%= link_to "New category", new_admin_category_path %>
</p>
