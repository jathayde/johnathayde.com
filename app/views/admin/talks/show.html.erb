<% if notice %><p class="flash-notice"><%= notice %></p><% end %>

<p class="breadcrumbs">
  <%= link_to "Admin", admin_path %> »
  <%= link_to "Talks", admin_talks_path %> »
</p>

<h1><%= @talk.title %></h1>

<% if @talk.subtitle.present? %>
  <p class="subtitle"><%= @talk.subtitle %></p>
<% end %>

<% if @talk.cover_image.attached? %>
  <section class="cover">
    <h2>Cover</h2>
    <%= image_tag @talk.cover_image, style: "max-width: 320px; display: block;" %>
  </section>
<% end %>

<%= simple_format @talk.description, class: "talk-description" %>

<% if @talk.speaker_deck_embed.present? %>
  <section class="speaker-deck">
    <h2>Slides</h2>
    <%= speaker_deck_embed @talk.speaker_deck_embed %>
  </section>
<% end %>

<% if @appearances.any? %>
  <section class="appearances">
    <h2>Appearances</h2>
    <ol>
      <% @appearances.each do |appearance| %>
        <li>
          <%= link_to appearance.event, admin_appearance_path(appearance) %>
          <span class="meta">
            (<%= appearance.location %>,
            <time datetime="<%= appearance.date.iso8601 %>">
              <%= appearance.date.stamp("04 May 2020") %>
            </time>)
          </span>
        </li>
      <% end %>
    </ol>
  </section>
<% end %>

<p class="admin-actions">
  <%= link_to "Edit", edit_admin_talk_path(@talk) %>
  <% if @talk.speaker_deck_embed.present? %>
    &middot;
    <%= button_to (@talk.cover_image.attached? ? "Re-fetch cover from SpeakerDeck" : "Fetch first slide from SpeakerDeck"),
                  fetch_cover_admin_talk_path(@talk),
                  method: :post,
                  class: "linklike",
                  data: { turbo_confirm: @talk.cover_image.attached? ? "Replace the existing cover?" : nil } %>
  <% end %>
  &middot;
  <%= button_to "Delete", admin_talk_path(@talk), method: :delete,
                data: { turbo_confirm: "Delete this talk and all its appearance links?" },
                class: "linklike" %>
  &middot;
  <%= link_to "View public", speaking_talk_path(@talk) %>
</p>
