<%= form_with(model: [:admin, talk]) do |form| %>
  <% if talk.errors.any? %>
    <div class="form-errors">
      <h2><%= pluralize(talk.errors.count, "error") %> prohibited this talk from being saved:</h2>
      <ul>
        <% talk.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :title %>
    <%= form.text_field :title, required: true %>
  </div>

  <div class="field">
    <%= form.label :subtitle %>
    <%= form.text_field :subtitle %>
  </div>

  <div class="field">
    <%= form.label :description %>
    <%= form.text_area :description, rows: 8, required: true %>
  </div>

  <div class="field">
    <%= form.label :speaker_deck_embed, "Speaker Deck embed" %>
    <%= form.text_area :speaker_deck_embed, rows: 3,
                       placeholder: '<script async class="speakerdeck-embed" data-id="..." data-ratio="..." src="//speakerdeck.com/assets/embed.js"></script>' %>
    <p class="hint">Paste the full <code>&lt;script&gt;</code> tag from Speaker Deck&rsquo;s share dialog.</p>
  </div>

  <div class="actions">
    <%= form.submit %>
  </div>
<% end %>
