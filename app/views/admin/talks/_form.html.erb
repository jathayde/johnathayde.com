<%= form_with(model: [:admin, talk], multipart: true) do |form| %>
  <% if talk.errors.any? %>
    <div class="form-errors">
      <h2><%= pluralize(talk.errors.count, "error") %> prohibited this talk from being saved:</h2>
      <ul>
        <% talk.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :title %>
    <%= form.text_field :title, required: true %>
  </div>

  <div class="field">
    <%= form.label :subtitle %>
    <%= form.text_field :subtitle %>
  </div>

  <div class="field">
    <%= form.label :description %>
    <%= form.text_area :description, rows: 8, required: true %>
  </div>

  <div class="field">
    <%= form.label :cover_image, "Cover image" %>
    <%= form.file_field :cover_image, accept: "image/*" %>
    <% if talk.cover_image.attached? %>
      <p class="hint">
        Current: <%= image_tag talk.cover_image, style: "max-width: 240px; display: block; margin-top: 0.5em;" %>
      </p>
    <% else %>
      <p class="hint">
        Upload manually, or save the talk first and use &ldquo;Fetch first slide from
        SpeakerDeck&rdquo; on the talk page to pull <code>slide_0.jpg</code> automatically.
      </p>
    <% end %>
  </div>

  <div class="field">
    <%= form.label :speaker_deck_embed, "Speaker Deck embed" %>
    <%= form.text_area :speaker_deck_embed, rows: 3,
                       placeholder: '<iframe src="https://speakerdeck.com/player/..." ...></iframe>' %>
    <p class="hint">
      Paste the <code>&lt;iframe&gt;</code> from Speaker Deck&rsquo;s share dialog,
      or the legacy <code>&lt;script class=&quot;speakerdeck-embed&quot;&gt;</code>
      tag &mdash; we&rsquo;ll render it as an iframe either way.
    </p>
  </div>

  <div class="actions">
    <%= form.submit %>
  </div>
<% end %>
