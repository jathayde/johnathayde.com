<% if notice %><p class="flash-notice"><%= notice %></p><% end %>

<p class="breadcrumbs"><%= link_to "Admin", admin_path %> » Articles</p>

<h1>Articles</h1>

<p class="admin-actions">
  <%= link_to "New article", new_admin_article_path %>
</p>

<table class="admin-table">
  <thead>
    <tr>
      <th>Title</th>
      <th>Status</th>
      <th>Published at</th>
      <th>Author</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @articles.each do |article| %>
      <tr id="<%= dom_id article %>">
        <td><%= link_to article.title, admin_article_path(article) %></td>
        <td>
          <% if article.published? %>
            <span class="badge published">Published</span>
          <% else %>
            <span class="badge unpublished">Draft</span>
          <% end %>
          <% if article.hidden_on_index %>
            <span class="badge unpublished">Hidden</span>
          <% end %>
        </td>
        <td>
          <% if article.published_at %>
            <time datetime="<%= article.published_at.iso8601 %>">
              <%= article.published_at.to_date.stamp("04 May 2020") %>
            </time>
          <% else %>
            —
          <% end %>
        </td>
        <td><%= article.author %></td>
        <td>
          <%= link_to "Edit", edit_admin_article_path(article) %>
          <% if article.published? %>
            &middot; <%= link_to "View public", article_path(article) %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
