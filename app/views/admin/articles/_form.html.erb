<%= form_with(model: [:admin, article]) do |form| %>
  <% if article.errors.any? %>
    <div class="form-errors">
      <h2><%= pluralize(article.errors.count, "error") %> prohibited this article from being saved:</h2>
      <ul>
        <% article.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <fieldset>
    <legend>Content</legend>

    <div class="field">
      <%= form.label :title %>
      <%= form.text_field :title, required: true %>
    </div>

    <div class="field">
      <%= form.label :subtitle %>
      <%= form.text_field :subtitle %>
    </div>

    <div class="field">
      <%= form.label :author %>
      <%= form.text_field :author %>
    </div>

    <div class="field">
      <%= form.label :body %>
      <%= form.rich_text_area :body %>
    </div>
  </fieldset>

  <fieldset>
    <legend>Publishing</legend>

    <div class="field">
      <%= form.label :category_id, "Category" %>
      <%= form.collection_select :category_id, Category.order(:name), :id, :name, include_blank: "— None —" %>
      <p class="hint">
        <%= link_to "Manage categories", admin_categories_path, target: "_blank", rel: "noopener" %>
        — opens in a new tab so this form keeps your draft; re-pick after adding one.
      </p>
    </div>

    <div class="field">
      <%= form.label :tag_list, "Tags" %>
      <%= form.text_field :tag_list, value: article.tag_list.to_s %>
      <p class="hint">Comma-separated, e.g. <code>rails, design systems</code>.</p>
    </div>

    <div class="field">
      <%= form.label :status %>
      <%= form.select :status, Article.statuses.keys.map { |s| [s.titleize, s] } %>
    </div>

    <div class="field">
      <%= form.label :published_at, "Publish at" %>
      <%= form.datetime_local_field :published_at %>
      <p class="hint">With status Published: blank = now, a future date = scheduled.</p>
    </div>

    <div class="field">
      <%= form.label :hidden_on_index do %>
        <%= form.check_box :hidden_on_index %>
        Hide from articles index (but keep reachable by URL)
      <% end %>
    </div>
  </fieldset>

  <fieldset>
    <legend>SEO & Social</legend>

    <div class="field">
      <%= form.label :page_title %>
      <%= form.text_field :page_title, required: true %>
      <p class="hint">Used as the &lt;title&gt; tag.</p>
    </div>

    <div class="field">
      <%= form.label :canonical_url, "Canonical URL" %>
      <%= form.url_field :canonical_url %>
      <p class="hint">Leave blank unless this was first published elsewhere (e.g. Meticulous.com) — search engines will credit that URL instead.</p>
    </div>

    <div class="field">
      <%= form.label :meta_description %>
      <%= form.text_area :meta_description, rows: 2, maxlength: 155, required: true %>
      <p class="hint">Max 155 characters.</p>
    </div>

    <div class="field">
      <%= form.label :feature_image, "Feature image" %>
      <%= form.file_field :feature_image, accept: "image/*" %>
      <% if article.feature_image.attached? %>
        <p class="hint">
          Current: <%= image_tag article.feature_image.variant(:card), style: "max-width: 240px;" %>
        </p>
      <% end %>
      <p class="hint">Optional. Shown on the index and post page, and used for social cards.</p>
    </div>

    <div class="field">
      <%= form.label :img_source, "Header image URL (legacy)" %>
      <%= form.url_field :img_source %>
      <p class="hint">Superseded by the feature image upload above.</p>
    </div>

    <h3>OpenGraph (optional overrides)</h3>
    <div class="field">
      <%= form.label :og_title %>
      <%= form.text_field :og_title %>
    </div>
    <div class="field">
      <%= form.label :og_description %>
      <%= form.text_area :og_description, rows: 2 %>
    </div>
    <div class="field">
      <%= form.label :og_image, "OG image URL" %>
      <%= form.url_field :og_image %>
    </div>

    <h3>Twitter / X (optional overrides)</h3>
    <div class="field">
      <%= form.label :twitter_title %>
      <%= form.text_field :twitter_title %>
    </div>
    <div class="field">
      <%= form.label :twitter_description %>
      <%= form.text_area :twitter_description, rows: 2 %>
    </div>
    <div class="field">
      <%= form.label :twitter_image, "Twitter image URL" %>
      <%= form.url_field :twitter_image %>
    </div>
  </fieldset>

  <div class="actions">
    <%= form.submit %>
  </div>
<% end %>
